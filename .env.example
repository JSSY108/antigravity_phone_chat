# Antigravity Phone Connect Configuration

# Your password for the mobile interface
# Used to secure your mobile dashboard
APP_PASSWORD=your-app-password

# Tunneling Configuration
# Priority: Named Tunnel > Ngrok > Quick Tunnel (Zero-Config Fallback)
# 
# 1. Named Tunnel (Pro Mode): Requires a custom domain and cloudflared login
TUNNEL_DOMAIN=         # e.g., yourdomain.com
TUNNEL_NAME=           # e.g., your-tunnel-name

# 2. ngrok (Legacy Fallback): Get a free token from https://dashboard.ngrok.com
NGROK_AUTHTOKEN=your-ngrok-authtoken

# NOTE: Leave TUNNEL_DOMAIN and TUNNEL_NAME blank to use the 
# zero-config Cloudflare Quick Tunnel automatically.

# AI Provider API Key
# Replace 'xxx' with your provider name (e.g., GROQ_API_KEY, GEMINI_API_KEY)
# xxx_API_KEY=your-xxx-key

# Server Port
PORT=3000

# Security (Optional - Change to invalidate all current sessions)
# SESSION_SECRET=your-random-session-secret-here
# AUTH_SALT=your-random-auth-salt-here
