# Antigravity Phone Connect Configuration

# Your password for the mobile interface
# Used to secure your mobile dashboard
APP_PASSWORD=your-app-password

# Tunneling Solution (cloudflare or ngrok)
# Cloudflare is recommended as it bypasses ngrok's 1GB/month limit
TUNNEL_TYPE=cloudflare

# Your ngrok authtoken (Get a free one from https://dashboard.ngrok.com)
# This prevents the 1-hour session limit and allows stable connections
# (Only used if TUNNEL_TYPE is set to ngrok or if cloudflare fails)
NGROK_AUTHTOKEN=your-ngrok-authtoken

# AI Provider API Key
# Replace 'xxx' with your provider name (e.g., GROQ_API_KEY, GEMINI_API_KEY)
# xxx_API_KEY=your-xxx-key

# Server Port
PORT=3000

# Security (Optional - Change to invalidate all current sessions)
# SESSION_SECRET=your-random-session-secret-here
# AUTH_SALT=your-random-auth-salt-here
